{
  "include": ["src/**/*.ts", "src/**/*.tsx", "vite.*.config.ts", "vite.*.config.mts", "forge.config.ts", "forge.env.d.ts"],
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/renderer/*"],
      "~/*": ["./src/renderer/*"]
    }
  }
}
